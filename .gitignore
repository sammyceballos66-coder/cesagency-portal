# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (.env.example is the exception — it documents required vars
# with no real secrets, so it should be committed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# large uncompressed source assets (keep locally, don't bloat git history)
reference/*.glb
reference/*.mp4

# sibling client projects nested in this same directory — separate codebases,
# not part of cesagency-portal
/aicontador-web/
/renault-pereira-web/
/quality-barber-shop-web/

# local tooling / agent config, not app code
/.claude/
/.gemini/
/.agents/
/.impeccable/
/.mcp.json
