# Copiar a .env.local y completar cuando existan las cuentas reales.
# Sin estas variables, el sitio funciona igual (el agente de WhatsApp queda
# simulado — ver lib/whatsapp-agent.ts).

# Número de WhatsApp de la agencia que ven los clientes en los botones del
# sitio, en formato internacional SIN "+" ni espacios (ej. 573001234567).
# Público a propósito (aparece en los links wa.me del sitio).
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Anthropic (https://console.anthropic.com) — el modelo que responde a los
# clientes por WhatsApp.
ANTHROPIC_API_KEY=
# Opcional: qué modelo usa el agente. Por defecto claude-haiku-4-5-20251001
# (rápido y económico para conversación). Se puede subir a un modelo más
# capaz si hace falta más calidad de respuesta.
WHATSAPP_AGENT_MODEL=

# Twilio (https://twilio.com) — canal por el que el agente manda y recibe
# los mensajes de WhatsApp. Meta Cloud API directo quedó bloqueado por
# verificación de cuenta pendiente; Twilio actúa de intermediario ya
# aprobado por Meta, así que no depende de esa verificación.
# 1. Cuenta de Twilio → Account Dashboard: copia Account SID y Auth Token.
# 2. Para pruebas: Messaging → Try it out → Send a WhatsApp message. Usa el
#    número de sandbox tal cual (ej. "whatsapp:+14155238886") en
#    TWILIO_WHATSAPP_FROM. Cada número que quiera hablar con el agente
#    (incluido NEXT_PUBLIC_WHATSAPP_NUMBER de abajo) debe mandarle primero
#    el código "join <palabra-palabra>" que te muestra esa pantalla.
# 3. Para producción real: Messaging → Senders → WhatsApp senders, registra
#    un número de WhatsApp Business propio (sin el paso de "join").
# 4. Configura el webhook "WHEN A MESSAGE COMES IN" (en Sandbox settings, o
#    en el sender real) apuntando a https://cesagencia.co/api/whatsapp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Vercel Blob (Storage → Create Database → Blob en el dashboard del
# proyecto) — guarda el historial de conversaciones de WhatsApp.
BLOB_READ_WRITE_TOKEN=

# Números de WhatsApp de los fundadores que reciben el resumen diario de
# clientes que quieren hablar personalmente. Separados por coma, formato
# internacional sin "+" (ej. 573001234567,573007654321).
AGENCY_WHATSAPP_NUMBERS=

# Vercel pone este valor solo en los cron jobs que él mismo dispara — no
# hay que llenarlo a mano, solo debe existir como variable de entorno en
# Vercel (Settings → Environment Variables) para que el endpoint del
# resumen diario (/api/whatsapp/digest) rechace llamadas externas.
CRON_SECRET=
